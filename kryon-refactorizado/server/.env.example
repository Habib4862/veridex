# Puerto del servidor (opcional, por defecto 3001)
PORT=3001

# Contraseña maestra que protege /api/* (la misma que se usa para entrar a KRYON)
ADMIN_CODE=kryon2026

# Supabase (persistencia). Usa la Service Role Key, NUNCA la anon key, aquí.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Anthropic (generación de demos con Claude). Si se omite, el backend responde
# con una plantilla HTML simple en vez de llamar a la API.
ANTHROPIC_API_KEY=

# Web Push (notificaciones). Genera el par con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
