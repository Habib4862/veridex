# Puerto del servidor (opcional, por defecto 3001)
PORT=3001

# Contraseña maestra que protege /api/* (la misma que se usa para entrar a KRYON)
ADMIN_CODE=AXIOM2000

# Supabase (persistencia). Usa la Service Role Key, NUNCA la anon key, aquí.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Anthropic NO se configura aquí: cada usuario pega su propia clave en
# Conexiones (frontend) y se reenvía solo en cada llamada a /api/claude/generate,
# igual que Resend/Stripe/Google Places. El backend nunca la guarda.

# Web Push (notificaciones). Genera el par con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
