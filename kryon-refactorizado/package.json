{
  "name": "kryon-refactorizado",
  "version": "1.0.0",
  "private": true,
  "description": "AXIOM CORE / KRYON — frontend modular vanilla JS con tests Vitest",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "desktop": "electron .",
    "desktop:build": "electron-builder"
  },
  "devDependencies": {
    "vitest": "^1.6.0",
    "jsdom": "^24.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.axiomcore.kryon",
    "productName": "AXIOM CORE - KRYON",
    "files": [
      "index.html",
      "manifest.json",
      "sw.js",
      "css/**/*",
      "js/**/*",
      "electron/**/*"
    ],
    "extraFiles": [
      { "from": "kryon.config.example.json", "to": "kryon.config.json" }
    ],
    "directories": { "output": "dist" },
    "electronLanguages": ["es", "es-419", "en-US"]
  }
}
